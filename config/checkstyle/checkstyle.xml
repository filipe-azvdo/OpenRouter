<?xml version="1.0"?>
<!DOCTYPE module PUBLIC
    "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
    "https://checkstyle.org/dtds/configuration_1_3.dtd">
<!--
  Ruleset curado (KAN-32): subconjunto de alto sinal do Google Java Style
  focado em higiene de imports. Gate o build sem exigir reformatação de
  indentação (2 vs 4 espaços). Ver agents.md §11.
-->
<module name="Checker">
    <property name="severity" value="error"/>
    <property name="charset" value="UTF-8"/>
    <property name="fileExtensions" value="java"/>

    <module name="TreeWalker">
        <module name="AvoidStarImport"/>
        <module name="RedundantImport"/>
        <module name="UnusedImports">
            <property name="processJavadoc" value="true"/>
        </module>
        <module name="CustomImportOrder">
            <!-- Bloco único, ASCII-alfabético, sem linhas em branco — casa com o
                 estilo dominante (ex.: RouteServiceImpl: com/java/lombok/org). -->
            <property name="customImportOrderRules" value="STATIC###THIRD_PARTY_PACKAGE"/>
            <property name="standardPackageRegExp" value="^$"/>
            <property name="thirdPartyPackageRegExp" value=".*"/>
            <property name="sortImportsInGroupAlphabetically" value="true"/>
            <property name="separateLineBetweenGroups" value="false"/>
        </module>
    </module>
</module>
